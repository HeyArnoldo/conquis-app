# ========================
# NestJS Backend - Environment Variables
# ========================

# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173

# MongoDB
MONGODB_URI=mongodb://localhost:27017/conquis_dev

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=conquis-files

# Public URL for MinIO (used by frontend to construct file URLs)
# In dev: http://localhost:9000 — In prod: your CDN or MinIO public URL
MINIO_PUBLIC_URL=http://localhost:9000

# Legacy (kept for backward compatibility, not used when MINIO_PUBLIC_URL is set)
# CEP_MODE=local
# API_URL=http://localhost:3000
# CEP_FILES_BASE_URL=
# CDN_URL=
